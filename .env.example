# Copy to .env for local `vercel dev` testing. Never commit the real .env file.

# Entire contents of the service account JSON key, as one line.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# The Sheet ID from its URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=

# Optional — see README section on cron auth before relying on this.
CRON_SECRET=
